# Figma API Configuration
FIGMA_ACCESS_TOKEN=your_figma_access_token_here

# Remote MCP Configuration (Phase 4)
# Enable connection to Figma's remote MCP server for write operations
FIGMA_REMOTE_MCP_ENABLED=false
FIGMA_REMOTE_MCP_ENDPOINT=https://mcp.figma.com/mcp
FIGMA_REMOTE_TIMEOUT=30000
FIGMA_REMOTE_RETRY=3
FIGMA_REMOTE_RETRY_DELAY=1000

# OAuth Configuration for Remote MCP
# Get these from: https://www.figma.com/developers/apps
# Required for npm run oauth:start
FIGMA_CLIENT_ID=your_oauth_client_id_here
FIGMA_CLIENT_SECRET=your_oauth_client_secret_here